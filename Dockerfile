## 1. Выбираем базовый образ
FROM python:3.11-slim

## 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

## 3. Копируем файл зависимостей
COPY requirements.txt .

## 4. Устанавливаем зависимости
# Используем --no-cache-dir для уменьшения размера образа
RUN pip install --no-cache-dir -r requirements.txt

## 5. Копируем весь код бота
# Точка "." означает копирование всего содержимого текущей папки, кроме файлов в .dockerignore
COPY . .

## 6. Определяем команду, которая запускается при старте контейнера
CMD ["python", "bot.py"]